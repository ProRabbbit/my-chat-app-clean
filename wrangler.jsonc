{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-chat-app-clean",
  "main": "src/index.js",
  "compatibility_date": "2026-03-01",
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_ROOM",
        "class_name": "ChatRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoom"]
    }
  ]
}